{
  "name": "nandi-proxmox-mcp",
  "mcpName": "io.github.NANDI-Services/nandi-proxmox-mcp",
  "version": "0.2.0",
  "description": "Open source Proxmox MCP server for secure VM/CT operations. Powered by NANDI Services.",
  "license": "MIT",
  "author": "NANDI Services",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "nandi-proxmox-mcp": "dist/src/cli/main.js"
  },
  "files": [
    "dist",
    "templates",
    "scripts",
    "mcp-manifest.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "if exist dist rmdir /s /q dist",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "validate:manifest": "node scripts/validate-manifest.mjs",
    "docs:tools": "node scripts/generate-tools-doc.mjs",
    "test:watch": "vitest",
    "start": "node dist/src/index.js",
    "cli": "node dist/src/cli/main.js",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.2",
    "commander": "^13.1.0",
    "express": "^4.21.2",
    "undici": "^7.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "eslint": "^9.25.1",
    "typescript-eslint": "^8.30.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
