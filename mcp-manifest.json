{
  "schema_version": "1.0",
  "id": "nandi-proxmox-mcp",
  "display_name": "NANDI Proxmox MCP",
  "description": "Open source Proxmox MCP server v0.2.3 with Core+Advanced security model, access tiers, and 143+ tools.",
  "transport": "stdio",
  "runtime": {
    "command": "npx",
    "args": ["nandi-proxmox-mcp", "run"],
    "env": {
      "NANDI_PROXMOX_CONFIG": "${workspaceFolder}/.nandi-proxmox-mcp/config.json"
    }
  },
  "docs": {
    "quickstart": "./docs/QUICKSTART.md",
    "security": "./docs/SECURITY.md",
    "troubleshooting": "./docs/TROUBLESHOOTING.md"
  }
}
